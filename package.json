{
  "name": "vue-zero-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "postinstall": "husky install",
  "pre-commit:init": "node -e \"require('fs').existsSync('.husky') || require('fs').mkdirSync('.husky');require('fs').writeFileSync('.husky/pre-commit','#!/usr/bin/env sh\\n. \\\"$(dirname -- \\\"$0\\\")/_/husky.sh\\\"\\n\\nnpx lint-staged\\n');process.platform === 'win32' || require('child_process').execSync('chmod +x .husky/pre-commit')\"",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "vue": "^3.5.34",
    "vue-hooks-plus": "^2.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,vue}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "npm run lint:fix"
    ],
    "*.{json,md,yml,yaml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
